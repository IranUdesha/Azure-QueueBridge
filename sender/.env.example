# Azure Storage Queue config
# Prefer using a limited-scope SAS or Entra ID in production.
# If you must use an access key, keep this file out of git and rotate keys regularly.

# Option A (recommended for this sample): full connection string
AZURE_STORAGE_CONNECTION_STRING="DefaultEndpointsProtocol=https;AccountName=YOUR_ACCOUNT_NAME;AccountKey=YOUR_ACCOUNT_KEY;EndpointSuffix=core.windows.net"

# Option B: build connection string from account name/key (if AZURE_STORAGE_CONNECTION_STRING is not set)
# AZURE_STORAGE_ACCOUNT_NAME="YOUR_ACCOUNT_NAME"
# AZURE_STORAGE_ACCOUNT_KEY="YOUR_ACCOUNT_KEY"
# AZURE_STORAGE_ENDPOINT_SUFFIX="core.windows.net"

AZURE_STORAGE_QUEUE_NAME="demo-queue"

# Sender API
PORT=8000
API_KEY=change-me-to-a-strong-random-key
API_KEY_HEADER_NAME=X-API-Key

# Sender settings
# Maximum time (seconds) a message can remain in the queue before Azure auto-deletes it,
# whether or not it was ever read by a consumer. This is NOT the invisibility timeout.
MESSAGE_TTL_SECONDS=3600

# SDK reliability
AZURE_SDK_TIMEOUT_SECONDS=30
AZURE_SDK_RETRY_TOTAL=5
AZURE_SDK_RETRY_BACKOFF_FACTOR=0.8
AZURE_SDK_RETRY_BACKOFF_MAX=30

# Logging
LOG_LEVEL=INFO

# Optional file logging (set both together)
# LOG_FILE_PATH=./logs
# LOG_FILE_NAME=sender.log
